# Copiar este archivo a .env.local y completar con los valores reales.
# Nunca commitear .env.local (ya está en .gitignore).

# ID de la app en Base44 (Builder > Settings)
VITE_BASE44_APP_ID=

# URL base del backend de la app en Base44
VITE_BASE44_APP_BASE_URL=

# Versión de las funciones de backend a usar (opcional, default = última publicada)
VITE_BASE44_FUNCTIONS_VERSION=
